<% title = 'Request Hapus Santri' %>
<%- include('partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h4><i class="fas fa-trash-alt"></i> Request Hapus Santri</h4>
            </div>
            <div class="card-body">
                <p>Anda akan meminta penghapusan data santri:</p>
                <p><strong>Nama:</strong> <%= santri.nama %></p>
                <p><strong>Kelas:</strong> <%= santri.kelas || '-' %></p>
                <p><strong>Juz:</strong> <%= santri.juz %></p>
                <hr>
                <form method="POST" action="/santri/request-delete/<%= santri.id %>">
                    <div class="mb-3">
                        <label class="form-label">Alasan Penghapusan <span class="text-danger">*</span></label>
                        <textarea name="reason" class="form-control" rows="3" required></textarea>
                    </div>
                    <% if (error) { %>
                        <div class="alert alert-danger"><%= error %></div>
                    <% } %>
                    <div class="d-flex justify-content-between">
                        <a href="/data-santri" class="btn btn-secondary">Batal</a>
                        <button type="submit" class="btn btn-primary">Kirim Request</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>