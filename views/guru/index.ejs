<% title = 'Manajemen Guru' %>
<%- include('../partials/header') %>

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><i class="fas fa-chalkboard-teacher"></i> Daftar Guru Tahfizh</h4>
        <a href="/guru/add" class="btn btn-light btn-sm"><i class="fas fa-plus"></i> Tambah Guru</a>
    </div>
    <div class="card-body">
        <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
        <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr><th>ID</th><th>Nama</th><th>Jabatan</th><th>Unit</th><th>Aksi</th></tr>
                </thead>
                <tbody>
                    <% if (guru && guru.length) { %>
                        <% guru.forEach(g => { %>
                        <tr>
                            <td><%= g.id %></td>
                            <td><%= g.nama %></td>
                            <td><%= g.jabatan || '-' %></td>
                            <td><%= g.unit || '-' %></td>
                            <td>
                                <a href="/guru/edit/<%= g.id %>" class="btn btn-sm btn-warning">Edit</a>
                                <a href="/guru/delete/<%= g.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Hapus guru ini?')">Hapus</a>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="5" class="text-center">Belum ada data guru</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>