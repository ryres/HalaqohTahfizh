<% title = 'Target Hafalan' %>
<%- include('partials/header') %>

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><i class="fas fa-bullseye"></i> Target Hafalan</h4>
        <div class="d-flex gap-2">
            <form method="GET" action="/data-santri/target-hafalan" class="d-flex">
                <input type="text" name="search" class="form-control form-control-sm me-2" placeholder="Cari nama/kelas..." value="<%= search %>">
                <button type="submit" class="btn btn-light btn-sm"><i class="fas fa-search"></i></button>
                <% if (search) { %>
                    <a href="/data-santri/target-hafalan" class="btn btn-secondary btn-sm ms-2">Reset</a>
                <% } %>
            </form>
            <select class="form-select form-select-sm w-auto" id="limitSelect">
                <option value="20" <%= limit == 20 ? 'selected' : '' %>>20</option>
                <option value="50" <%= limit == 50 ? 'selected' : '' %>>50</option>
                <option value="100" <%= limit == 100 ? 'selected' : '' %>>100</option>
            </select>
            <!-- pdf -->
            <a href="/target-hafalan/pdf?<%= new URLSearchParams({ search, sort: sortBy, order, limit }).toString() %>" class="btn btn-danger btn-sm" target="_blank"><i class="fas fa-file-pdf"></i> Cetak PDF</a>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th><a href="?sort=nama&order=<%= sortBy === 'nama' && order === 'asc' ? 'desc' : 'asc' %><%= search ? '&search='+search : '' %>&limit=<%= limit %>&page=<%= currentPage %>" class="text-white text-decoration-none">Nama <i class="fas fa-sort"></i></a></th>
                        <th><a href="?sort=kelas&order=<%= sortBy === 'kelas' && order === 'asc' ? 'desc' : 'asc' %><%= search ? '&search='+search : '' %>&limit=<%= limit %>&page=<%= currentPage %>" class="text-white text-decoration-none">Kelas <i class="fas fa-sort"></i></a></th>
                        <th><a href="?sort=target_juz&order=<%= sortBy === 'target_juz' && order === 'asc' ? 'desc' : 'asc' %><%= search ? '&search='+search : '' %>&limit=<%= limit %>&page=<%= currentPage %>" class="text-white text-decoration-none">Target <i class="fas fa-sort"></i></a></th>
                        <th><a href="?sort=pencapaian&order=<%= sortBy === 'pencapaian' && order === 'asc' ? 'desc' : 'asc' %><%= search ? '&search='+search : '' %>&limit=<%= limit %>&page=<%= currentPage %>" class="text-white text-decoration-none">Pencapaian <i class="fas fa-sort"></i></a></th>
                        <th><a href="?sort=sisa&order=<%= sortBy === 'sisa' && order === 'asc' ? 'desc' : 'asc' %><%= search ? '&search='+search : '' %>&limit=<%= limit %>&page=<%= currentPage %>" class="text-white text-decoration-none">Sisa <i class="fas fa-sort"></i></a></th>
                        <th><a href="?sort=durasi&order=<%= sortBy === 'durasi' && order === 'asc' ? 'desc' : 'asc' %><%= search ? '&search='+search : '' %>&limit=<%= limit %>&page=<%= currentPage %>" class="text-white text-decoration-none">Durasi <i class="fas fa-sort"></i></a></th>
                        <th><a href="?sort=periode&order=<%= sortBy === 'periode' && order === 'asc' ? 'desc' : 'asc' %><%= search ? '&search='+search : '' %>&limit=<%= limit %>&page=<%= currentPage %>" class="text-white text-decoration-none">Periode <i class="fas fa-sort"></i></a></th>
                        <th><a href="?sort=tgl_awal&order=<%= sortBy === 'tgl_awal' && order === 'asc' ? 'desc' : 'asc' %><%= search ? '&search='+search : '' %>&limit=<%= limit %>&page=<%= currentPage %>" class="text-white text-decoration-none">Tgl Awal <i class="fas fa-sort"></i></a></th>
                        <th><a href="?sort=tgl_akhir&order=<%= sortBy === 'tgl_akhir' && order === 'asc' ? 'desc' : 'asc' %><%= search ? '&search='+search : '' %>&limit=<%= limit %>&page=<%= currentPage %>" class="text-white text-decoration-none">Tgl Akhir <i class="fas fa-sort"></i></a></th>
                    </tr>
                </thead>
                <tbody>
                    <% if (data && data.length > 0) { %>
                        <% data.forEach(item => { %>
                        <tr>
                            <td><%= item.nama %></td>
                            <td><%= item.kelas %></td>
                            <td><%= item.target %></td>
                            <td><%= item.pencapaian %></td>
                            <td><%= item.sisa %></td>
                            <td><%= item.durasiHari %></td>
                            <td><%= item.periode %></td>
                            <td><%= item.tgl_awal %></td>
                            <td><%= item.tgl_akhir %></td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="9" class="text-center">Tidak ada data</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        <div class="d-flex justify-content-between mt-3">
            <div>Total <%= totalRecords %> data</div>
            <nav>
                <ul class="pagination">
                    <% if (currentPage > 1) { %>
                    <li class="page-item"><a class="page-link" href="?page=<%= currentPage-1 %>&limit=<%= limit %><%= search ? '&search='+search : '' %>&sort=<%= sortBy %>&order=<%= order %>">Prev</a></li>
                    <% } %>
                    <% for (let i=1; i<=totalPages; i++) { %>
                        <li class="page-item <%= i === currentPage ? 'active' : '' %>"><a class="page-link" href="?page=<%= i %>&limit=<%= limit %><%= search ? '&search='+search : '' %>&sort=<%= sortBy %>&order=<%= order %>"><%= i %></a></li>
                    <% } %>
                    <% if (currentPage < totalPages) { %>
                    <li class="page-item"><a class="page-link" href="?page=<%= currentPage+1 %>&limit=<%= limit %><%= search ? '&search='+search : '' %>&sort=<%= sortBy %>&order=<%= order %>">Next</a></li>
                    <% } %>
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
    document.getElementById('limitSelect').addEventListener('change', function() {
        const url = new URL(window.location.href);
        url.searchParams.set('limit', this.value);
        url.searchParams.set('page', 1);
        window.location.href = url.toString();
    });
</script>

<%- include('partials/footer') %>