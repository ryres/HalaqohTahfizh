<% title = 'Manajemen Halaqoh' %>
<%- include('../partials/header') %>

<div class="card">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><i class="fas fa-users"></i> Daftar Halaqoh</h4>
        <a href="/halaqoh/add" class="btn btn-light btn-sm"><i class="fas fa-plus"></i> Tambah Halaqoh</a>
    </div>
    <div class="card-body">
        <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
        <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nama Halaqoh</th>
                        <th>Pembimbing</th>
                        <th>Jadwal</th>
                        <th>Ruangan</th>
                        <th>Jumlah Santri</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (halaqoh && halaqoh.length) { %>
                        <% halaqoh.forEach(h => { %>
                        <tr>
                            <td><%= h.id %></td>
                            <td><%= h.nama_halaqoh %></td>
                            <td><%= h.nama_guru || '-' %>   <!-- nama_guru dari hasil JOIN di route -->
                            <td><%= h.jadwal || '-' %></td>
                            <td><%= h.ruangan || '-' %></td>
                            <td><%= h.jumlah_santri || 0 %></td>
                            <td>
                                <a href="/halaqoh/detail/<%= h.id %>" class="btn btn-sm btn-info">Detail</a>
                                <a href="/halaqoh/edit/<%= h.id %>" class="btn btn-sm btn-warning">Edit</a>
                                <a href="/halaqoh/delete/<%= h.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Hapus?')">Hapus</a>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="7" class="text-center">Belum ada data halaqoh</td><tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>