<% title = 'Akses Ditolak' %>
<%- include('partials/header') %>

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card shadow-lg border-0">
            <div class="card-body p-5">
                <i class="fas fa-ban fa-5x text-danger mb-4"></i>
                <h1 class="display-4 fw-bold text-danger">403</h1>
                <h3 class="mb-3">Akses Ditolak</h3>
                <p class="text-muted mb-4">Maaf, halaman ini hanya dapat diakses oleh administrator.</p>
                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                    <% if (user) { %>
                        <a href="/dashboard/<%= user.role %>" class="btn btn-primary me-2">
                            <i class="fas fa-tachometer-alt"></i> Dashboard
                        </a>
                    <% } %>
                    <a href="/" class="btn btn-outline-secondary">
                        <i class="fas fa-home"></i> Halaman Utama
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>