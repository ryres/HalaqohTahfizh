    </div>
    <script>
        function updateClocks() {
            const d = new Date();
            const jakarta = new Date(d.toLocaleString("en-US", { timeZone: "Asia/Jakarta" }));
            const mecca = new Date(d.toLocaleString("en-US", { timeZone: "Asia/Riyadh" }));
            if (document.getElementById('jakarta-time')) {
                document.getElementById('jakarta-time').innerHTML = `Jakarta: ${jakarta.toLocaleTimeString('id-ID')}`;
            }
            if (document.getElementById('mecca-time')) {
                document.getElementById('mecca-time').innerHTML = `Makkah: ${mecca.toLocaleTimeString('id-ID')}`;
            }
        }
        setInterval(updateClocks, 1000);
        updateClocks();

        // Toggle sidebar responsif
        const toggleBtn = document.getElementById('toggleSidebarBtn');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        if (toggleBtn && sidebar && overlay) {
            toggleBtn.onclick = () => {
                sidebar.classList.toggle('show');
                overlay.classList.toggle('show');
            };
            overlay.onclick = () => {
                sidebar.classList.remove('show');
                overlay.classList.remove('show');
            };
        }

        // Submenu handling: hover di desktop, click di mobile
        function initSubmenu() {
            const submenuTriggers = document.querySelectorAll('.has-submenu > a');
            const isMobile = window.innerWidth <= 991.98;
            submenuTriggers.forEach(trigger => {
                const parentLi = trigger.parentNode;
                // Hapus event listener lama (pakai clone untuk reset)
                const newTrigger = trigger.cloneNode(true);
                trigger.parentNode.replaceChild(newTrigger, trigger);
                if (isMobile) {
                    newTrigger.addEventListener('click', (e) => {
                        e.preventDefault();
                        parentLi.classList.toggle('open');
                    });
                } else {
                    parentLi.addEventListener('mouseenter', () => {
                        parentLi.classList.add('open');
                    });
                    parentLi.addEventListener('mouseleave', () => {
                        parentLi.classList.remove('open');
                    });
                }
            });
        }
        initSubmenu();
        window.addEventListener('resize', () => {
            initSubmenu();
        });

        async function loadNotifications() {
    const res = await fetch('/api/notifications');
    const data = await res.json();
    const badge = document.getElementById('notifBadge');
    if (data.unreadCount > 0) {
        badge.innerText = data.unreadCount;
        badge.style.display = 'inline-block';
    } else {
        badge.style.display = 'none';
    }
    const container = document.getElementById('notifList');
    container.innerHTML = '';
    if (data.notifications.length === 0) {
        container.innerHTML = '<div class="dropdown-item text-muted">Tidak ada notifikasi</div>';
    } else {
        data.notifications.forEach(n => {
            const div = document.createElement('div');
            div.className = `dropdown-item ${n.is_read ? '' : 'bg-light'}`;
            div.innerHTML = `<strong>${n.title}</strong><br><small>${n.message}</small><br><small class="text-muted">${new Date(n.created_at).toLocaleString()}</small>`;
            if (!n.is_read) {
                div.style.cursor = 'pointer';
                div.onclick = () => markAsRead(n.id);
            }
            if (n.link) {
                div.onclick = () => window.location.href = n.link;
            }
            container.appendChild(div);
        });
    }
}
function markAsRead(id) {
    fetch(`/api/notifications/${id}/read`, { method: 'POST' }).then(() => loadNotifications());
}
setInterval(loadNotifications, 30000);
loadNotifications();

    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    

</body>
