<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Tahfizh App' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f4f6f9;
            overflow-x: hidden;
        }
        /* Sidebar */
        .sidebar {
            position: fixed;
            top: 0;
            left: -280px;
            width: 280px;
            height: 100%;
            background: #2c3e50;
            color: white;
            transition: left 0.3s ease;
            z-index: 1050;
            box-shadow: 2px 0 5px rgba(0,0,0,0.2);
            overflow-y: auto;
        }
        .sidebar.show {
            left: 0;
        }
        .sidebar-header {
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid #34495e;
        }
        .sidebar-header h4 {
            margin: 0;
            font-size: 1.3rem;
        }
        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 20px 0;
        }
        .sidebar-menu li {
            position: relative;
        }
        .sidebar-menu li a {
            display: block;
            padding: 12px 20px;
            color: #ecf0f1;
            text-decoration: none;
            transition: 0.3s;
        }
        .sidebar-menu li a:hover {
            background: #1abc9c;
            color: white;
        }
        .sidebar-menu li a i {
            margin-right: 10px;
            width: 20px;
        }
        /* Submenu styling */
        .sidebar-menu .submenu {
            list-style: none;
            padding-left: 30px;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease-out;
        }
        .sidebar-menu .submenu li a {
            padding: 8px 20px;
            font-size: 0.9rem;
        }
        .sidebar-menu .has-submenu > a::after {
            content: '\f078';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            float: right;
            transition: transform 0.3s;
        }
        .sidebar-menu .has-submenu.open > a::after {
            transform: rotate(180deg);
        }
        .sidebar-menu .has-submenu.open .submenu {
            max-height: 300px; /* cukup untuk 3-4 item */
        }
        /* Responsive: di mobile, submenu menggunakan display block/none */
        @media (max-width: 991.98px) {
            .sidebar-menu .submenu {
                max-height: none;
                display: none;
            }
            .sidebar-menu .has-submenu.open .submenu {
                display: block;
            }
            .sidebar-menu .has-submenu > a::after {
                content: '\f054';
            }
            .sidebar-menu .has-submenu.open > a::after {
                content: '\f078';
            }
        }
        .user-info {
            padding: 15px 20px;
            border-top: 1px solid #34495e;
            margin-top: 20px;
        }
        .user-info .user-avatar {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }
        .user-info .user-avatar i {
            font-size: 2rem;
        }
        .logout-btn {
            display: block;
            background: #e74c3c;
            color: white;
            text-align: center;
            padding: 10px;
            border-radius: 5px;
            text-decoration: none;
            margin-top: 10px;
        }
        .logout-btn:hover {
            background: #c0392b;
            color: white;
        }
        /* Overlay & toggle */
        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1040;
            display: none;
        }
        .sidebar-overlay.show {
            display: block;
        }
        .toggle-sidebar {
            position: fixed;
            top: 15px;
            left: 15px;
            z-index: 1060;
            background: #2c3e50;
            color: white;
            border: none;
            border-radius: 5px;
            padding: 8px 12px;
            cursor: pointer;
            transition: 0.3s;
        }
        .toggle-sidebar:hover {
            background: #1abc9c;
        }
        .main-content {
            margin-left: 0;
            transition: margin-left 0.3s ease;
            padding: 20px;
        }
        @media (min-width: 992px) {
            .sidebar {
                left: 0;
            }
            .sidebar.show {
                left: 0;
            }
            .main-content {
                margin-left: 280px;
            }
            .toggle-sidebar {
                display: none;
            }
        }
        @media (max-width: 991.98px) {
            .main-content {
                margin-left: 0;
            }
        }
    </style>
</head>
<body>
<% if (typeof user !== 'undefined' && user) { %>
    <button class="toggle-sidebar" id="toggleSidebarBtn"><i class="fas fa-bars"></i></button>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <h4><i class="fas fa-quran"></i> Tahfizh App</h4>
        </div>
       <ul class="sidebar-menu">
    <!-- Dashboard selalu tampil untuk semua role -->
<li><a href="/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>    <!-- Menu untuk admin -->
    <% if (user.role === 'admin') { %>
        <li><a href="/admin/delete-requests"><i class="fas fa-clipboard-list"></i> Request Hapus</a></li>
        <li><a href="/data-santri"><i class="fas fa-users"></i> Data Santri</a></li>
        <li class="has-submenu">
            <a href="#"><i class="fas fa-mosque"></i> Manajemen Tahfizh</a>
            <ul class="submenu">
                <li><a href="/tahfizh/clustering"><i class="fas fa-chart-line"></i> Tahfizh (Clustering)</a></li>
                <li><a href="/data-santri/target-hafalan"><i class="fas fa-bullseye"></i> Target Hafalan</a></li>
                <li><a href="/halaqoh"><i class="fas fa-users"></i> Manajemen Halaqoh</a></li>
                <li><a href="/guru"><i class="fas fa-chalkboard-teacher"></i> Guru Tahfizh</a></li>
            </ul>
        </li>
        <li><a href="/users"><i class="fas fa-user-shield"></i> User</a></li>
        <li><a href="/logs"><i class="fas fa-history"></i> Log Aktivitas</a></li>
    <% } else if (user.role === 'guru_tahfizh') { %>
        <!-- Menu untuk guru tahfizh -->
        <li><a href="/data-santri"><i class="fas fa-users"></i> Data Santri</a></li>
        <li><a href="/delete-requests/status"><i class="fas fa-clock"></i> Status Request</a></li>
    <% } else { %>
        <!-- User biasa: hanya dashboard, tidak ada menu tambahan -->
    <% } %>
</ul>
        <div class="user-info">
            <div class="user-avatar">
                <i class="fas fa-user-circle fa-2x"></i>
                <span><%= user.username %></span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </div>
    <div class="main-content" id="mainContent">
        <div class="row mb-2">
            <%- include('breadcrumb') %>
            <div class="col text-end">
                <span id="jakarta-time" class="badge bg-secondary me-2">Jakarta: --:--:--</span>
                <span id="mecca-time" class="badge bg-secondary">Makkah: --:--:--</span>
                <div class="dropdown d-inline-block me-3">
    <button class="btn btn-secondary position-relative" type="button" id="notificationDropdown" data-bs-toggle="dropdown">
        <i class="fas fa-bell"></i>
        <span id="notifBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none;">0</span>
    </button>
    <div class="dropdown-menu dropdown-menu-end" style="width: 300px;" aria-labelledby="notificationDropdown">
        <h6 class="dropdown-header">Notifikasi</h6>
        <div id="notifList" style="max-height: 300px; overflow-y: auto;"></div>
        <div class="dropdown-divider"></div>
        <a class="dropdown-item text-center" href="#" id="markAllRead">Tandai semua sudah dibaca</a>
    </div>
</div>
            </div>
        </div>
<% } else { %>
    <div class="container mt-4">
<% } %>