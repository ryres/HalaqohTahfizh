<% title = 'Login' %>
<%- include('partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body text-center">
                <!-- Logo (ikon Font Awesome) -->
                <i class="fas fa-quran fa-3x text-primary mb-3"></i>
                <!-- Judul Aplikasi -->
                <h4 class="card-title mb-1">Aplikasi Pembuatan Halaqoh Tahfizh</h4>
                <!-- Versi (h6 kecil) -->
                <h6 class="text-muted mb-4">v0.1</h6>
                
                <% if (error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                <% if (success) { %>
                    <div class="alert alert-success"><%= success %></div>
                <% } %>
                <form method="POST" action="/login">
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" name="username" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Login</button>
                </form>
                <hr>
                <p class="text-center">Belum punya akun? <a href="/register">Daftar</a></p>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>